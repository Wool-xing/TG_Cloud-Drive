# ─────────────────────────────────────────────────────────────────────────────
# TG 云盘 — Environment Variables Template
#
# Copy this file to .env and replace ALL `CHANGE_ME_*` values with real secrets.
# Never commit .env to version control (.gitignore covers it).
#
# Run `make doctor` after editing to verify no `CHANGE_ME_*` placeholders remain.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Application ─────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000

# Public URL of the frontend (used in email links etc.)
APP_URL=https://your.domain.com


# ─── Database (PostgreSQL) ───────────────────────────────────────────────────

DB_NAME=tgpan
DB_USER=tgpan
# REQUIRED — change to a strong random password (≥ 32 chars, mix of upper/lower/digit/symbol)
DB_PASS=CHANGE_ME_strong_database_password

# DATABASE_URL is what the NestJS backend actually reads.
# Docker Compose constructs it automatically from DB_USER / DB_PASS / DB_NAME.
# For local dev (no Docker), set this to point at localhost:
DATABASE_URL=postgresql://tgpan:CHANGE_ME_strong_database_password@localhost:5432/tgpan
DATABASE_SSL=false


# ─── Redis ────────────────────────────────────────────────────────────────────

# REDIS_URL is what the NestJS backend reads.
# Docker Compose overrides this to redis://redis:6379 automatically.
REDIS_URL=redis://localhost:6379

# REQUIRED for production — Redis MUST have a password when exposed beyond localhost
REDIS_PASS=CHANGE_ME_redis_password


# ─── JWT / Auth ───────────────────────────────────────────────────────────────

# REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_64_hex_chars

# REQUIRED — must be a DIFFERENT secret from JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret_at_least_64_hex_chars


# ─── Encryption ──────────────────────────────────────────────────────────────

# REQUIRED — 32-byte hex key for server-side AES-256-GCM (email/phone field encryption)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Rotating this key WILL make existing encrypted email/phone fields unreadable.
ENCRYPTION_MASTER_KEY=CHANGE_ME_64_hex_chars_for_aes256_master_key


# ─── Telegram Bot ────────────────────────────────────────────────────────────

# REQUIRED — Bot token from @BotFather
TG_BOT_TOKEN=CHANGE_ME_telegram_bot_token

# REQUIRED — Private channel ID where files are stored (bot must be admin)
TG_CHANNEL_ID=CHANGE_ME_telegram_channel_id


# ─── Cloudflare Workers ──────────────────────────────────────────────────────

# REQUIRED in production — URL of your deployed Cloudflare Worker.
#
# P1-B20: leaving this blank in production = zero-day bot token leak. The
# backend's getFileUrl() returns https://api.telegram.org/file/bot{TOKEN}/...
# directly to the browser when this is empty, so the very first download
# reveals your bot token to any authenticated user (DevTools / proxy log /
# share-link target). env-validator enforces this in production startup.
#
# Dev / local-only: leave this BLANK. Backend uses direct Telegram API
# (bot token stays server-side, errors are sanitized). Do NOT leave blank
# in production — env-validator will block startup.
#
# Production: deploy worker with `cd worker && npx wrangler deploy`, then
# paste the Workers URL here (e.g. https://tgpan-relay.your-subdomain.workers.dev).
CF_WORKERS_URL=

# REQUIRED if CF_WORKERS_URL is set — shared secret between backend and Worker
CF_WORKERS_SECRET=CHANGE_ME_workers_shared_secret


# ─── SMTP (Email) ────────────────────────────────────────────────────────────

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=CHANGE_ME_smtp_password
SMTP_FROM=TG云盘 <noreply@example.com>


# ─── Storage & Limits ────────────────────────────────────────────────────────

# Default quota for new users (GB)
DEFAULT_USER_QUOTA_GB=50

# Max folders per directory
MAX_FOLDERS_PER_DIR=10

# Trash auto-cleanup (days)
TRASH_RETENTION_DAYS=30


# ─── Admin ────────────────────────────────────────────────────────────────────

# REQUIRED — admin account username (e.g. "admin"). Pick anything unique.
ADMIN_USERNAME=CHANGE_ME_admin_username

# REQUIRED — initial password for the admin account (created by seed script).
# Must be a strong random value. Backend + seed script both refuse to start
# if this is left as CHANGE_ME_* or any known weak default (e.g. Admin@123456).
ADMIN_INITIAL_PASSWORD=CHANGE_ME_admin_initial_password


# ─── Frontend Build-time Variables ───────────────────────────────────────────

# Baked into the JS bundle at build time — do NOT put secrets here
VITE_API_BASE_URL=/api


# ─── Docker / Compose Port Mappings ──────────────────────────────────────────

BACKEND_PORT=3000
